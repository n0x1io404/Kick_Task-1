<?xml version="1.0" encoding="UTF-8" ?>
<Configuration status="info">
    <Properties>
        <Property name="patternConsole">%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</Property>
        <Property name="patternLogFile">%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${patternConsole}"/>
        </Console>

        <File name="LogFile" fileName="logs/logs.log">
            <PatternLayout pattern="${patternLogFile}"/>
        </File>
    </Appenders>
ф
    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="LogFile"/>
        </Root>
    </Loggers>
</Configuration>